NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Set to "true" to bypass Supabase entirely and browse both dashboards
# (Fresher + PM) with static in-memory demo data. Do not enable in production.
NEXT_PUBLIC_DEMO_MODE=false

# Calls OpenAI directly from the browser (roadmap generation, code
# evaluation, viva questions, weekly/final reports) — no backend proxy.
# This ships the key in the client bundle, readable by anyone who opens
# devtools. Known, accepted tradeoff for this phase — do not use a
# production/unrestricted key here.
OPENAI_API_KEY=
